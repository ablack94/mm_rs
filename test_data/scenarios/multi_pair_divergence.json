      ]
    },
    "CAMP/USD": {
      "starting_price": 0.004,
      "waypoints": [
        { "t_ms": 0,     "mid": 0.004 },
        { "t_ms": 60000, "mid": 0.0034 }
      ]
    }
  },
  "end_behavior": "hold_last"
}
